version:
  revision: "UNKNOWN"
  channel: "stable"

project_type: app

# Tracks metadata for the flutter migrate command
migration:
  platforms:
    - platform: root
      create_revision: "UNKNOWN"
      base_revision: "UNKNOWN"
    - platform: ios
      create_revision: "UNKNOWN"
      base_revision: "UNKNOWN"

  # User provided section

  # List of Local Coverage Exclusion Paths (Coverage Exclusion is local only and target coverage is determined in the Coverage Exclusion Paths section)
  unmanaged_files:
    - 'lib/main.dart'
    - 'ios/Runner.xcodeproj/project.pbxproj'
